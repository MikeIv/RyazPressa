# Локальная разработка: какой сайт показывать на localhost
# После смены значения перезапустите: pnpm dev
#
# Полный реестр slug → shared/sites/manifest.json (+ ryazpressa отдельно)
# Альтернатива без .env: curl -H "Host: nesecretno.ru" http://localhost:3000/api/_site
# Подробнее: docs/dev-multi-site.md

# --- Расширенный сайт (округа, проекты, «Рядом с нами»; без галереи) ---
# ryazpressa — ryazpressa.ru
NUXT_SITE_SLUG=ryazpressa

# --- Базовые издания (главная, gallery, documents, contacts) ---
# nesecretno              — nesecretno.ru
# rodnoykray62            — rodnoykray62.ru
# denzadnem               — denzadnem.su
# rodnieistoki            — rodnieistoki.ru
# nashibudni              — nashibudni.ru
# vteme62                 — vteme62.ru
# ezhednevnik62           — ezhednevnik62.ru
# nashazhizn              — нашажизнь.com
# zvezda62                — zvezda62.ru
# po-sushchestvu          — по-существу.рф
# vseputem62              — vseputem62.ru
# naslukhu                — наслуху.su
# rbninfo                 — rbninfo.ru
# chestnye-vesti          — честные-вести.рф
# prigorodnoe-soobshchenie — пригородное-сообщение.рф
# vokruge62               — vokruge62.ru
# zemlyaki                — zemlyaki.su
# nedelya-novostey        — неделя-новостей.su
# mezhdu-strok            — между-строк.рф
# vkursedela              — vkursedela.online
# pulseoflife             — pulseoflife.ru
# bezvariantov62          — bezvariantov62.ru
# iskra                   — искра.online
# nashevremya62           — nashevremya62.ru
# storonka62              — storonka62.ru

# Запасной base URL API (обычно задаётся здесь для прокси Nitro → бэкенд)
NUXT_PUBLIC_API_BASE=https://api.ryazpressa.ru

# Mock API в Nitro (по умолчанию включён). false — прокси на бэкенд через serverApi.
# NUXT_USE_MOCK_API=false
